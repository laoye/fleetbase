<Modal::Default @modalIsOpened={{@modalIsOpened}} @options={{@options}} @confirm={{@onConfirm}} @decline={{@onDecline}}>
    <div class="modal-body-container pt-0i text-gray-900 dark:text-white">
        {{#if @options.isOwner}}
            {{#if @options.hasOtherMembers}}
                <p>
                    <div class="text-base mb-2">
                        {{t "console.account.organizations.owner-leave-msg" organizationName=@options.organization.name}}
                    </div>
                    <div>{{t "console.account.organizations.select-owner-help"}}</div>
                </p>
                <InputGroup @name={{t "console.account.organizations.select-new-owner"}} @wrapperClass="mt-2 mb-0i">
                    <Select
                        @options={{@options.organization.users}}
                        @value={{@options.newOwnerId}}
                        @onSelect={{@options.selectNewOwner}}
                        @optionLabel="name"
                        @optionValue="id"
                        @placeholder={{t "console.account.organizations.select-member"}}
                    />
                </InputGroup>
            {{else if @options.willBeDeleted}}
                <p>
                    <div class="text-base mb-2">
                        {{t "console.account.organizations.sole-owner-msg" organizationName=@options.organization.name}}
                    </div>
                    <div>{{t "console.account.organizations.sole-owner-delete-warning"}}</div>
                    <div>{{t "console.account.organizations.confirm-proceed"}}</div>
                </p>
                <p class="mt-3"><em>{{t "console.account.organizations.cannot-be-undone"}}</em></p>
            {{/if}}
        {{else}}
            <p>
                <div class="text-base mb-2">
                    {{t "console.account.organizations.leave-confirm-msg" organizationName=@options.organization.name}}
                </div>
                <div>{{t "console.account.organizations.leave-access-warning"}}</div>
            </p>
        {{/if}}
    </div>
</Modal::Default>